# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# Vertex AI Configuration
VERTEX_AI_MODEL=gemini-1.5-pro
VERTEX_AI_EMBEDDING_MODEL=textembedding-gecko@003

# BigQuery Configuration
BIGQUERY_DATASET=property_compliance
BIGQUERY_LAND_RECORDS_TABLE=land_records
BIGQUERY_TAX_RECORDS_TABLE=tax_records
BIGQUERY_COMPLIANCE_RULES_TABLE=compliance_rules
BIGQUERY_LOAN_POLICIES_TABLE=loan_policies
BIGQUERY_TRANSACTIONS_TABLE=transactions

# Cloud Storage Configuration
GCS_BUCKET_NAME=property-compliance-documents
GCS_PROCESSED_FOLDER=processed
GCS_UPLOADS_FOLDER=uploads

# Document AI Configuration
DOCUMENT_AI_PROCESSOR_ID=your-processor-id
DOCUMENT_AI_PROCESSOR_LOCATION=us

# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# WebSocket Configuration
WS_PORT=3001

# Security
JWT_SECRET=your-jwt-secret-key
API_KEY=your-api-key

# Logging
LOG_LEVEL=info